    "national": false,
    "section": "Kecerdasan AQ",
    "scale": "Nilai-nilai AQ dan Budi"
  },
  {
    "text": "Saya dapat membuat sesuatu terjadi dengan segala macam cara.",
    "options": ["0", "1", "2", "3"],
    "type": "AQ_scale",
    "national": false,
    "section": "Kecerdasan AQ",
    "scale": "Nilai-nilai AQ dan Budi"
  },
  {
    "text": "Kalau saya memikirkan hidup saya, saya mungkin menemukan bahwa saya adalah seorang yang berperilaku jahat.",
